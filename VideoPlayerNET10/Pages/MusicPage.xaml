<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="VideoPlayerNET10.Pages.MusicPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Music">

    <Grid RowDefinitions="Auto,Auto,*">

        <SearchBar
            Grid.Row="0"
            x:Name="SearchBox"
            Placeholder="Search Music"
            TextChanged="SearchChanged"/>

        <CollectionView
            Grid.Row="1"
            x:Name="TagView"
            HeightRequest="80"
            SelectionChanged="TagSelected">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Border
                        Margin="5"
                        Padding="8"
                        BackgroundColor="#2A2A2A">

                        <HorizontalStackLayout
                            Spacing="8">

                            <Image
                                Source="{Binding IconPath}"
                                WidthRequest="24"
                                HeightRequest="24"/>

                            <Label
                                Text="{Binding Name}"
                                FontAttributes="Bold"/>

                            <Label
                                Text="{Binding Count,
                                StringFormat='({0})'}"/>

                        </HorizontalStackLayout>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

        <CollectionView
            Grid.Row="2"
            x:Name="MusicCollection"
            SelectionChanged="MusicSelected">

            <CollectionView.ItemsLayout>

                <GridItemsLayout
                    Orientation="Vertical"
                    Span="2"/>

            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Border
                        Margin="8"
                        Padding="10"
                        BackgroundColor="#222222">

                        <VerticalStackLayout>

                            <Label
                                Text="{Binding Title}"
                                FontAttributes="Bold"
                                FontSize="18"/>

                            <Label
                                Text="{Binding Artist}"
                                FontSize="14"/>

                            <Label
                                Text="{Binding Stars}"
                                TextColor="Gold"/>

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
