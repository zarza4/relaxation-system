<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="VideoPlayerNET10.Pages.VideoDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <AbsoluteLayout>

        <!-- BACKGROUND LAYERS -->
        <Image
            x:Name="BgA"
            Source="background_default.png"
            Aspect="AspectFill"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

        <Image
            x:Name="BgB"
            Source="background_default.png"
            Aspect="AspectFill"
            Opacity="0"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

        <!-- DARK OVERLAY -->
        <BoxView
            Color="#66000000"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

        <!-- CONTENT -->
        <ScrollView
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All">

            <VerticalStackLayout
                Padding="20"
                Spacing="12">

                <!-- BACK BUTTON -->
                <Grid HeightRequest="55">

                    <Image Source="button.png" Aspect="Fill"/>

                    <Button
                        Text="← Back"
                        BackgroundColor="Transparent"
                        TextColor="#333"
                        FontSize="20"
                        FontAttributes="Bold"
                        Clicked="BackClicked"/>
                </Grid>

                <!-- VIDEO INFO -->
                <Image
                    x:Name="ThumbnailImage"
                    HeightRequest="250"
                    Aspect="AspectFill"/>

                <Label x:Name="TitleLabel"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label x:Name="ResolutionLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <Label x:Name="ResolutionTextLabel"
                       FontSize="14"
                       TextColor="White"/>

                <Label x:Name="RatingLabel"
                       FontSize="20"
                       TextColor="Gold"/>

                <Label x:Name="DescriptionLabel"
                       TextColor="White"/>

                <!-- TAGS -->
                <Label Text="Tags"
                       FontAttributes="Bold"
                       TextColor="White"/>

                <FlexLayout
                    x:Name="TagsLayout"
                    Wrap="Wrap"
                    Direction="Row"/>

                <!-- CAPTIONS -->
                <Label x:Name="CaptionInfoLabel"
                       FontAttributes="Italic"
                       TextColor="White"/>

                <Switch x:Name="CaptionsSwitch"/>

                <!-- BUTTONS -->
                <Button
                    Text="Select Music"
                    Clicked="SelectMusicClicked"/>

                <Button
                    Text="Use this Video"
                    Clicked="PlayVideoClicked"/>

            </VerticalStackLayout>

        </ScrollView>

        <!-- TRANSITION OVERLAY -->
        <BoxView
            x:Name="TransitionOverlay"
            BackgroundColor="White"
            Opacity="0"
            InputTransparent="True"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

    </AbsoluteLayout>

</ContentPage>
