<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="VideoPlayerNET10.Pages.VideoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <AbsoluteLayout>

        <!-- BACKGROUND A -->
        <Image
            x:Name="BgA"
            Source="background_default.png"
            Aspect="AspectFill"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

        <!-- BACKGROUND B -->
        <Image
            x:Name="BgB"
            Source="background_default.png"
            Aspect="AspectFill"
            Opacity="0"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

        <!-- DARK OVERLAY -->
        <BoxView
            Color="#66000000"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

        <!-- CONTENT -->
        <Grid
            Padding="20"
            RowDefinitions="Auto,Auto,Auto,*"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All">

            <!-- BACK -->
            <Grid Grid.Row="0" HeightRequest="55">
                <Image Source="button.png" Aspect="Fill"/>
                <Button
                    Text="← Back"
                    Clicked="BackClicked"
                    BackgroundColor="Transparent"
                    TextColor="#333"
                    FontSize="20"
                    FontAttributes="Bold"/>
            </Grid>

            <!-- SEARCH -->
            <SearchBar
                Grid.Row="1"
                x:Name="SearchBox"
                Placeholder="Search Tags..."
                BackgroundColor="#AA000000"
                TextColor="White"
                PlaceholderColor="#CCCCCC"
                TextChanged="SearchChanged"/>

            <!-- TAGS -->
            <CollectionView
                Grid.Row="2"
                x:Name="TagView"
                HeightRequest="95"
                SelectionMode="Single"
                SelectionChanged="TagSelected">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border
                            Margin="6"
                            WidthRequest="640"
                            HeightRequest="96"
                            StrokeThickness="4.5"
                            Stroke="#E0C88A"
                            StrokeShape="RoundRectangle 36">

                            <Grid ColumnDefinitions="60,*">

                                <Image
                                    Source="{Binding IconPath}"
                                    WidthRequest="64"
                                    HeightRequest="64"
                                    Aspect="AspectFit"
                                    VerticalOptions="Center"/>

                                <Grid Grid.Column="1">

                                    <Image
                                        Source="{Binding BackgroundPath}"
                                        Aspect="AspectFill"/>

                                    <VerticalStackLayout Padding="12">

                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="White"/>

                                        <Label
                                            Text="{Binding Count,StringFormat='{0} videos'}"
                                            FontSize="12"
                                            TextColor="#E0C88A"/>
                                    </VerticalStackLayout>

                                </Grid>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- VIDEOS -->
            <CollectionView
                Grid.Row="3"
                x:Name="VideoCollection"
                SelectionMode="Single"
                SelectionChanged="VideoSelected">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border
                            Margin="10"
                            Padding="10"
                            BackgroundColor="#AA000000"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 15">

                            <VerticalStackLayout Spacing="8">

                                <Image
                                    Source="{Binding ThumbnailPath}"
                                    HeightRequest="220"
                                    Aspect="AspectFill"/>

                                <Label
                                    Text="{Binding Title}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="White"/>

                                <Label Text="{Binding Stars}" TextColor="Gold"/>
                                <Label Text="{Binding ResolutionLabel}" TextColor="White"/>

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Grid>

        <!-- FADE OVERLAY -->
        <BoxView
            x:Name="TransitionOverlay"
            BackgroundColor="White"
            Opacity="0"
            InputTransparent="True"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"/>

    </AbsoluteLayout>

</ContentPage>
