<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="VideoPlayerNET10.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background -->
        <Image
            Source="background_default.png"
            Aspect="AspectFill" />

        <!-- Dark overlay for readability -->
        <BoxView
            Color="#66000000" />

        <ScrollView>

            <VerticalStackLayout
                Padding="40"
                Spacing="20"
                VerticalOptions="Center">

                <!-- Title -->

                <Label
                    Text="VIDEO PLAYER"
                    FontSize="42"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    TextColor="White" />

                <Label
                    Text="Media Collection Manager"
                    FontSize="18"
                    HorizontalOptions="Center"
                    TextColor="#DDDDDD" />

                <!-- Collection -->

                <Border
                    BackgroundColor="#AA000000"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 15"
                    Padding="15">

                    <VerticalStackLayout>

                        <Label
                            Text="Current Collection"
                            FontAttributes="Bold"
                            FontSize="18"
                            TextColor="#E0C88A" />

                        <Label
                            x:Name="CollectionLabel"
                            Text="No Collection Selected"
                            FontSize="16"
                            TextColor="White" />

                    </VerticalStackLayout>

                </Border>

                <!-- Select Collection -->

                <Grid
                    HeightRequest="60">

                    <Image
                        Source="button.png"
                        Aspect="Fill" />

                    <Button
                        Text="Select Collection"
                        Clicked="SelectCollectionClicked"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        TextColor="#333333"
                        FontSize="22"
                        FontAttributes="Bold" />

                </Grid>

                <!-- Videos -->

                <Grid
                    HeightRequest="60">

                    <Image
                        Source="button.png"
                        Aspect="Fill" />

                    <Button
                        Text="Videos"
                        Clicked="VideosClicked"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        TextColor="#333333"
                        FontSize="22"
                        FontAttributes="Bold" />

                </Grid>

                <!-- Music -->

                <Grid
                    HeightRequest="60">

                    <Image
                        Source="button.png"
                        Aspect="Fill" />

                    <Button
                        Text="Music"
                        Clicked="MusicClicked"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        TextColor="#333333"
                        FontSize="22"
                        FontAttributes="Bold" />

                </Grid>

                <!-- Player -->

                <Grid
                    HeightRequest="60">

                    <Image
                        Source="button.png"
                        Aspect="Fill" />

                    <Button
                        Text="Player"
                        Clicked="PlayerClicked"
                        BackgroundColor="Transparent"
                        BorderColor="Transparent"
                        TextColor="#333333"
                        FontSize="22"
                        FontAttributes="Bold" />

                </Grid>

            </VerticalStackLayout>

        </ScrollView>

        <BoxView
            x:Name="TransitionOverlay"
            BackgroundColor="White"
            Opacity="0"
            InputTransparent="True"/>

    </Grid>

</ContentPage>
