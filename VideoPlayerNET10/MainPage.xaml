<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="VideoPlayerNET10.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Video Player">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15"
>

            <Label
                Text="Welcome to the Video Player."
                FontSize="32"
                FontAttributes="Bold"
                FontFamily="HanyiWenHei"
                HorizontalOptions="Center"/>

            <Border
                BackgroundColor="#222222">

                <Label
                    x:Name="CollectionLabel"
                    FontFamily="HanyiWenHei"
                    Text="No Collection Selected"/>
            </Border>

            <Button
                Text="Select Collection"
                FontFamily="HanyiWenHei"
                Clicked="SelectCollectionClicked"/>

            <Button
                Text="Videos"
                Clicked="VideosClicked"/>

            <Button
                Text="Music"
                Clicked="MusicClicked"/>

            <Button
                Text="Player"
                Clicked="PlayerClicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>